# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# ChromaDB (backend local, padrão)
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=study_chunks

# pgvector / Supabase — se definido, pgvector é usado automaticamente no lugar do Chroma
DATABASE_URL=

# Notion (opcional — só necessário para save_summary_tool/save_flashcards_tool)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64